#include <iostream>
#include <fstream>  
#include <string>  
#include <Windows.h>


int main() 
{
    SetConsoleCP(1251);
    SetConsoleOutputCP(1251);

    std::ifstream ifile("in.txt");   

    if (!ifile.is_open()) 
    {
        std::cout << "Ошибка: файл in.txt не найден!" << std::endl;
    }

    std::string word;

    while (ifile >> word) 
    {  
        std::cout << word << std::endl;
    }

    ifile.close();  

    return EXIT_SUCCESS;
}
